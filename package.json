{
  "name": "@holmhq/sdk",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "description": "The universal TypeScript SDK for Holm apps and surfaces.",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holmhq/sdk.git"
  },
  "homepage": "https://github.com/holmhq/sdk#readme",
  "bugs": {
    "url": "https://github.com/holmhq/sdk/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck:core": "tsc -p tsconfig.core.json --noEmit",
    "test:source": "tsc -p tsconfig.test-source.json && node --test .tmp/test-source/test/source/core/index.test.js",
    "test:types": "tsc -p tsconfig.test-types.core.json --noEmit && tsc -p tsconfig.test-types.web.json --noEmit && tsc -p tsconfig.test-types.node.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.5.0"
  }
}
