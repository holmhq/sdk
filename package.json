{
  "name": "@holmhq/sdk",
  "version": "0.2.1",
  "type": "module",
  "description": "The universal strict-TypeScript SDK for building Holm apps.",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "docs",
    "examples",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "holm",
    "typescript",
    "sdk",
    "bfbb"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./transports": {
      "types": "./dist/transports/index.d.ts",
      "import": "./dist/transports/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.js"
    },
    "./app": {
      "types": "./dist/app/index.d.ts",
      "import": "./dist/app/index.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./sobek": {
      "types": "./dist/sobek/index.d.ts",
      "import": "./dist/sobek/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "import": "./dist/test/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holmhq/sdk.git"
  },
  "homepage": "https://github.com/holmhq/sdk#readme",
  "bugs": {
    "url": "https://github.com/holmhq/sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && node scripts/write-web-bundles.mjs && npm run test:stable-api && npm run check:licenses && npm run size && node scripts/write-dist-manifest.mjs",
    "check:licenses": "node scripts/check-licenses.mjs",
    "check:repro": "node scripts/check-repro.mjs",
    "ci": "npm run typecheck:core && npm run test:types && npm run test:source && npm run test:admin-api && npm run test:ci-workflow && npm run test:publish-workflow && npm run test:docs && npm run check:repro && npm run test:declarations && npm run test:dist && npm run test:examples && npm run test:coverage && npm run check:licenses && npm run size && npm run test:package",
    "coverage": "npm run test:coverage",
    "prepublishOnly": "npm run release:check",
    "release:check": "npm run build && npm run ci",
    "size": "node scripts/size.mjs",
    "test:admin-api": "node scripts/check-admin-api.mjs",
    "test:ci-workflow": "node scripts/check-ci-workflow.mjs",
    "test:coverage": "node scripts/coverage.mjs && node scripts/check-coverage-summary.mjs",
    "test:declarations": "npm run test:stable-api && tsc -p tsconfig.test-declarations.json --noEmit && tsc -p tsconfig.test-declarations-web.json --noEmit",
    "test:dist": "node --test test/dist/index.test.mjs",
    "test:docs": "node scripts/check-release-docs.mjs",
    "test:examples": "node scripts/test-examples.mjs",
    "test:holm-admin-authority": "node scripts/check-admin-holm-authority.mjs",
    "test:holm-smoke": "node scripts/holm-app-smoke.mjs",
    "test:package": "node scripts/check-package.mjs",
    "test:publish-workflow": "node scripts/check-publish-workflow.mjs",
    "test:source": "node scripts/test-source.mjs",
    "test:stable-api": "node scripts/check-stable-api.mjs",
    "test:types": "tsc -p tsconfig.test-types.core.json --noEmit && tsc -p tsconfig.test-types.web.json --noEmit && tsc -p tsconfig.test-types.node.json --noEmit",
    "typecheck:core": "tsc -p tsconfig.core.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.5.0",
    "vite": "^6.4.3"
  }
}
